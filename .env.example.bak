# =====================================================
# CMS Talents – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage echte Werte ein.
# .env wird nicht ins Repo committed (.gitignore).
# =====================================================

# --- Datenbank (Supabase / PostgreSQL) ---
# Für Vercel/Serverless: Connection Pooling URL nutzen (Port 6543).
# Supabase: Project Settings → Database → Connection string (Transaction mode).
POSTGRES_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Alternativ (eine der folgenden reicht):
# DATABASE_URL=
# POSTGRES_URL_NON_POOLING=
# PRISMA_DATABASE_URL=

# --- Optional: API Keys (z.B. Gemini, falls vom Backend genutzt) ---
# GEMINI_API_KEY=
# API_KEY=
